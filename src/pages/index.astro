---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Accueil">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-container">
      <div class="hero-content">
        <span class="tag">Intervention 24/7 à Bruxelles</span>
        <h1 class="hero-title">Votre Expert en <span class="text-primary">Plomberie</span> et <span class="text-primary">Débouchage</span></h1>
        <p class="hero-desc">
          Une urgence plomberie ? Une canalisation bouchée ? Vartista intervient rapidement et efficacement. Notre équipe de professionnels qualifiés est à votre service.
        </p>
        <div class="hero-actions">
          <a href="tel:+32000000000" class="btn btn-primary btn-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Appeler Maintenant
          </a>
          <a href="/services" class="btn btn-outline btn-lg">
            Nos Services
          </a>
        </div>
        
        <div class="hero-features">
          <div class="feature-item">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <span>Intervention en 30 min</span>
          </div>
          <div class="feature-item">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <span>Travail Garanti</span>
          </div>
          <div class="feature-item">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <span>Devis Transparent</span>
          </div>
        </div>
      </div>
      <div class="hero-image-wrapper">
        <div class="hero-image-container glass-card">
          <img src="https://images.unsplash.com/photo-1607472586893-edb57cbceb42?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Plombier professionnel au travail" class="hero-image" />
          
          <div class="floating-badge badge-1 glass-card">
            <div class="badge-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg>
            </div>
            <div>
              <strong>100% Satisfait</strong>
              <p>Clients locaux</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="section bg-light" id="services">
    <div class="container">
      <div class="section-header text-center">
        <span class="tag">Notre Expertise</span>
        <h2>Services de Qualité Professionnelle</h2>
        <p class="section-desc">Découvrez nos solutions adaptées à tous vos problèmes de plomberie et de canalisations.</p>
      </div>

      <div class="grid grid-cols-3">
        <!-- Service 1 -->
        <div class="service-card glass-card">
          <div class="service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><path d="M12 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/></svg>
          </div>
          <h3>Plomberie Générale</h3>
          <p>Installation, réparation et entretien de vos équipements sanitaires. Fuites, robinetterie, chauffe-eau.</p>
          <a href="/services#plomberie" class="service-link">
            En savoir plus
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

        <!-- Service 2 -->
        <div class="service-card glass-card">
          <div class="service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m16 12-4-4-4 4"/><path d="M12 16V8"/></svg>
          </div>
          <h3>Débouchage</h3>
          <p>Intervention rapide pour déboucher vos éviers, toilettes, baignoires et canalisations principales.</p>
          <a href="/services#debouchage" class="service-link">
            En savoir plus
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

        <!-- Service 3 -->
        <div class="service-card glass-card">
          <div class="service-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="m17 5-5-3-5 3"/><path d="m17 19-5 3-5-3"/><path d="M2 12h20"/><path d="m5 7 3 5-3 5"/><path d="m19 7-3 5 3 5"/></svg>
          </div>
          <h3>Chauffage</h3>
          <p>Entretien et réparation de chaudières, radiateurs et systèmes de chauffage central.</p>
          <a href="/services#chauffage" class="service-link">
            En savoir plus
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="cta-bg"></div>
    <div class="container relative z-10 text-center">
      <h2>Besoin d'une intervention urgente ?</h2>
      <p>Nos plombiers sont prêts à intervenir à Bruxelles et ses alentours dans les plus brefs délais.</p>
      <div class="cta-buttons">
        <a href="tel:+32000000000" class="btn btn-primary btn-lg">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          02 000 00 00
        </a>
        <a href="/contact" class="btn btn-secondary btn-lg">
          Demander un devis en ligne
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .text-primary {
    color: var(--primary);
  }

  /* Hero Section */
  .hero {
    position: relative;
    padding: 6rem 0;
    overflow: hidden;
    min-height: calc(100vh - 5rem);
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    top: -50%;
    right: -20%;
    width: 80%;
    height: 150%;
    background: radial-gradient(circle, rgba(2,132,199,0.1) 0%, rgba(2,132,199,0) 70%);
    z-index: -1;
    border-radius: 50%;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 992px) {
    .hero-container {
      grid-template-columns: 1fr 1fr;
    }
  }

  .hero-title {
    margin-bottom: 1.5rem;
  }

  .hero-desc {
    font-size: 1.125rem;
    margin-bottom: 2.5rem;
    max-width: 500px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .btn-lg {
    padding: 1rem 2rem;
    font-size: 1.125rem;
  }

  .hero-features {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 500;
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--accent);
    color: var(--primary);
    border-radius: 50%;
  }

  .hero-image-wrapper {
    position: relative;
  }

  .hero-image-container {
    padding: 1rem;
    transform: rotate(2deg);
    transition: var(--transition);
  }

  .hero-image-container:hover {
    transform: rotate(0deg);
  }

  .hero-image {
    border-radius: var(--radius);
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .floating-badge {
    position: absolute;
    bottom: -2rem;
    left: -2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    animation: float 6s ease-in-out infinite;
  }

  .badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: #10b981;
    color: white;
    border-radius: 50%;
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }

  /* Section Styles */
  .bg-light {
    background-color: var(--bg-light);
  }

  .section-header {
    margin-bottom: 4rem;
    max-width: 700px;
    margin-inline: auto;
  }

  .section-header h2 {
    margin: 1rem 0;
  }

  .section-desc {
    font-size: 1.125rem;
  }

  .service-card {
    padding: 2.5rem;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .service-card:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-lg);
    border-color: var(--primary-light);
  }

  .service-icon-wrapper {
    width: 4rem;
    height: 4rem;
    background: var(--accent);
    color: var(--primary);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: var(--transition);
  }

  .service-card:hover .service-icon-wrapper {
    background: var(--primary);
    color: white;
  }

  .service-card h3 {
    margin-bottom: 1rem;
  }

  .service-card p {
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary);
    font-weight: 600;
  }

  .service-link svg {
    transition: transform 0.3s ease;
  }

  .service-card:hover .service-link svg {
    transform: translateX(5px);
  }

  /* CTA Section */
  .cta-section {
    position: relative;
    padding: 6rem 0;
    color: white;
    overflow: hidden;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    background-color: var(--primary-dark);
    background-image: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%);
    z-index: 1;
  }

  .cta-section .container {
    position: relative;
    z-index: 10;
  }

  .cta-section h2 {
    color: white;
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.25rem;
    color: var(--accent);
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-inline: auto;
  }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }
</style>
